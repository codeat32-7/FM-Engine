# Gemini API (server / Vite define)
GEMINI_API_KEY=

# Supabase — used by Vite client via define (SUPABASE_* aliases) and by API routes
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional explicit client vars (same values as above if you prefer)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Twilio sandbox WhatsApp (Dashboard QR / wa.me)
# Sandbox number is often +1 415 523 8886 — confirm in Twilio console.
# VITE_TWILIO_WHATSAPP_NUMBER=14155238886
# Exact phrase from Twilio Sandbox (NOT your sites.code in the database)
# VITE_TWILIO_SANDBOX_JOIN=join bad-color
# Alias without VITE_ prefix (also wired in vite.config):
# TWILIO_SANDBOX_JOIN=join bad-color

# Twilio API (server)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
